# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: groq | anthropic | openai | huggingface
LLM_PROVIDER=groq

# ── Groq (fast, free tier available) ─────────────────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
# Other good Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Hugging Face Inference API (open models) ──────────────────────────────────
# https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_...
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local Docker:  QDRANT_URL=http://localhost:6333  (leave QDRANT_API_KEY blank)
# Qdrant Cloud:  fill both fields
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=medibot-dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── DB ────────────────────────────────────────────────────────────────────────
DB_PATH=data/db/mediassist.db

# ── Embedding / reranker (run locally via sentence-transformers, no API cost) ──
DENSE_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
